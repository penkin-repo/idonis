# === Telegram ===
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Произвольная секретная строка. Передаётся при setWebhook (параметр secret_token)
# и проверяется в /api/bot. Придумай длинную случайную строку.
TELEGRAM_SECRET_TOKEN=

# === OpenRouter (LLM) ===
# Ключ OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Модель. Можно менять в любой момент без изменения кода.
# Примеры: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, google/gemini-flash-1.5
OPENROUTER_MODEL=
# Модель для аналитика/чата (продвинутее, чем логер). Если пусто — берётся OPENROUTER_MODEL.
# Примеры: anthropic/claude-3.5-sonnet, openai/gpt-4o, google/gemini-2.0-flash-001
OPENROUTER_MODEL_ANALYST=openai/gpt-4o-mini

# === Turso DB ===
# libsql://<db-name>-<org>.turso.io
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# === Приложение ===
# Публичный URL проекта на Vercel (нужен OpenRouter для заголовка HTTP-Referer)
APP_URL=https://your-project.vercel.app
# Таймзона по умолчанию для новых пользователей
USER_TZ=Europe/Moscow
